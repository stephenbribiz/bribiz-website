---
// Variant A for the old newsletter slot: the blog teaser becomes a
// full-width row of the latest posts.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => !data.archived))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="blog-teaser">
  <div class="container">
    <h2 class="section-heading">Industry News + Blog</h2>
    <div class="teaser-grid">
      {posts.map((post) => (
        <a href={`/${post.id}/`} class="teaser-card">
          <Image src={post.data.image} alt={post.data.imageAlt || post.data.title} width={600} height={338} />
          <div class="teaser-card-body">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="teaser-more">Read More »</span>
          </div>
        </a>
      ))}
    </div>
    <p class="teaser-all">
      <a href="/blog/" class="btn">View All Posts</a>
    </p>
  </div>
</section>

<style>
  .blog-teaser {
    background: var(--color-gray-section);
    padding: 72px 0 64px;
  }

  .teaser-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 16px;
  }

  .teaser-card {
    background: var(--color-white);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .teaser-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    color: var(--color-text);
  }

  .teaser-card-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .teaser-card h3 {
    font-size: 21px;
    margin-bottom: 10px;
  }

  .teaser-card p {
    font-size: 16px;
    color: var(--color-text-muted);
    flex: 1;
  }

  .teaser-more {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-orange-dark);
    font-size: 15px;
    text-transform: uppercase;
  }

  .teaser-all {
    text-align: center;
    margin: 40px 0 0;
  }

  @media (max-width: 900px) {
    .teaser-grid { grid-template-columns: 1fr; }
  }
</style>
