---
import { Image } from 'astro:assets';
import logoWhite from '../assets/logo-white.png';
import bgBuilding from '../assets/backgrounds/bg-building.jpg';

const year = new Date().getFullYear();

const footerNav = [
  { label: 'Home', href: '/' },
  { label: 'What We Do', href: '/whatwedo/' },
  { label: 'Who We Are', href: '/who-we-are/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Schedule Free Conversation', href: '/book-a-consultation/' },
  { label: 'Contact', href: '/contact/' },
];

const socials = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/BriBiz-Entertainment-Business-Management-353498004663607/',
    path: 'M13.5 9H15V6h-1.5C11.57 6 10 7.57 10 9.5V11H8v3h2v7h3v-7h2.1l.4-3H13v-1.5c0-.28.22-.5.5-.5z',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/brian-smith-83629727/',
    path: 'M6.94 8.5A1.72 1.72 0 1 1 6.94 5a1.72 1.72 0 0 1 0 3.5zM5.5 10h2.88v9H5.5v-9zm4.62 0h2.76v1.23h.04c.38-.72 1.32-1.48 2.72-1.48 2.9 0 3.44 1.91 3.44 4.39V19h-2.88v-4.34c0-1.04-.02-2.37-1.45-2.37-1.45 0-1.67 1.13-1.67 2.3V19h-2.96v-9z',
  },
  {
    label: 'X (Twitter)',
    href: 'https://www.twitter.com/officialbribiz',
    path: 'M17.53 6h2.1l-4.59 5.25L20.44 19h-4.23l-3.31-4.33L9.1 19H7l4.91-5.61L6.72 6h4.34l3 3.96L17.53 6zm-.74 11.74h1.16L10.43 7.2H9.18l7.61 10.54z',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/bribizmgmt/',
    path: 'M12 8.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5zm0 5.77a2.27 2.27 0 1 1 0-4.54 2.27 2.27 0 0 1 0 4.54zM16.7 8.36a.82.82 0 1 1-1.64 0 .82.82 0 0 1 1.64 0zM12 6.62c1.75 0 1.96.01 2.65.04.64.03 1 .14 1.23.23.31.12.53.26.76.5.23.23.38.45.5.76.09.23.2.59.23 1.23.03.69.04.9.04 2.65s-.01 1.96-.04 2.65c-.03.64-.14 1-.23 1.23-.12.31-.27.53-.5.76a2.05 2.05 0 0 1-.76.5c-.23.09-.59.2-1.23.23-.69.03-.9.04-2.65.04s-1.96-.01-2.65-.04c-.64-.03-1-.14-1.23-.23a2.05 2.05 0 0 1-.76-.5 2.05 2.05 0 0 1-.5-.76c-.09-.23-.2-.59-.23-1.23-.03-.69-.04-.9-.04-2.65s.01-1.96.04-2.65c.03-.64.14-1 .23-1.23.12-.31.27-.53.5-.76.23-.24.45-.38.76-.5.23-.09.59-.2 1.23-.23.69-.03.9-.04 2.65-.04zM12 5.4c-1.78 0-2 .01-2.7.04-.7.03-1.18.14-1.6.31-.43.17-.8.4-1.16.76-.37.37-.6.73-.76 1.17-.17.41-.28.89-.31 1.59-.03.7-.04.92-.04 2.7s.01 2 .04 2.7c.03.7.14 1.18.31 1.6.17.43.4.8.76 1.16.37.36.73.6 1.17.76.41.17.89.28 1.59.31.7.03.92.04 2.7.04s2-.01 2.7-.04c.7-.03 1.18-.14 1.6-.31.43-.17.8-.4 1.16-.76.36-.37.6-.73.76-1.17.17-.41.28-.89.31-1.59.03-.7.04-.92.04-2.7s-.01-2-.04-2.7c-.03-.7-.14-1.18-.31-1.6a3.23 3.23 0 0 0-.76-1.16 3.23 3.23 0 0 0-1.17-.76c-.41-.17-.89-.28-1.59-.31-.7-.03-.92-.04-2.7-.04z',
  },
];
---

<footer class="site-footer">
  <div class="footer-bg" style={`background-image: url(${bgBuilding.src})`}>
    <div class="footer-overlay">
      <div class="container footer-inner">
        <Image src={logoWhite} alt="BriBiz" width={215} height={80} class="footer-logo" />
        <address class="footer-contact">
          135 5th Ave S, Suite 240, Franklin, TN 37064<br />
          Phone: <a href="tel:615-390-7083">615-390-7083</a> · Fax: 615-887-0284<br />
          <a href="mailto:info@bribiz.net">info@bribiz.net</a>
        </address>
        <nav class="footer-nav" aria-label="Footer">
          {footerNav.map((item, i) => (
            <>
              {i > 0 && <span class="footer-nav-sep">|</span>}
              <a href={item.href}>{item.label}</a>
            </>
          ))}
        </nav>
        <div class="footer-socials">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d={s.path} />
              </svg>
            </a>
          ))}
        </div>
        <p class="footer-copyright">
          Copyright {year} BriBiz Entertainment Business Management | All Rights Reserved
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-bg {
    background-size: cover;
    background-position: center;
  }

  .footer-overlay {
    background: rgba(20, 20, 20, 0.82);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    padding-top: 64px;
    padding-bottom: 48px;
    text-align: center;
  }

  .footer-contact {
    font-style: normal;
    color: #d8d8d8;
    font-size: 16px;
    line-height: 1.8;
  }

  .footer-contact a { color: var(--color-white); }
  .footer-contact a:hover { color: var(--color-orange); }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    font-family: var(--font-heading);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-nav a { color: var(--color-white); }
  .footer-nav a:hover { color: var(--color-orange); }
  .footer-nav-sep { color: rgba(255, 255, 255, 0.35); }

  .footer-socials {
    display: flex;
    gap: 18px;
  }

  .footer-socials a {
    color: var(--color-white);
    display: inline-flex;
    padding: 6px;
  }

  .footer-socials a:hover { color: var(--color-orange); }

  .footer-copyright {
    margin: 0;
    color: #9a9a9a;
    font-size: 14px;
  }
</style>
