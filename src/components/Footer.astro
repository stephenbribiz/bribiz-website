---
import { Image, getImage } from 'astro:assets';
import logoWhite from '../assets/logo-white.png';
import bgBuildingSrc from '../assets/backgrounds/bg-building.jpg';
import { BLOG_ENABLED } from '../config';
import { socials } from '../data/socials';

const bgBuilding = await getImage({ src: bgBuildingSrc, width: 1920, format: 'webp' });
const year = new Date().getFullYear();

const footerNav = [
  { label: 'Home', href: '/' },
  { label: 'What We Do', href: '/whatwedo/' },
  { label: 'Who We Are', href: '/who-we-are/' },
  ...(BLOG_ENABLED ? [{ label: 'Blog', href: '/blog/' }] : []),
  { label: 'Schedule Free Conversation', href: '/book-a-consultation/' },
  { label: 'Contact', href: '/contact/' },
];

---

<footer class="site-footer">
  <div class="footer-bg" style={`background-image: url(${bgBuilding.src})`}>
    <div class="footer-overlay">
      <div class="container footer-inner">
        <Image src={logoWhite} alt="BriBiz" width={215} height={85} densities={[1, 2]} class="footer-logo" />
        <address class="footer-contact">
          135 5th Ave S, Suite 240, Franklin, TN 37064<br />
          Phone: <a href="tel:615-390-7083">615-390-7083</a> · Fax: 615-887-0284<br />
          <a href="mailto:info@bribiz.net">info@bribiz.net</a>
        </address>
        <nav class="footer-nav" aria-label="Footer">
          {footerNav.map((item, i) => (
            <>
              {i > 0 && <span class="footer-nav-sep">|</span>}
              <a href={item.href}>{item.label}</a>
            </>
          ))}
        </nav>
        <div class="footer-socials">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d={s.path} />
              </svg>
            </a>
          ))}
        </div>
        <p class="footer-copyright">
          Copyright {year} BriBiz Entertainment Business Management | All Rights Reserved
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-bg {
    background-size: cover;
    background-position: center;
  }

  .footer-overlay {
    background: rgba(20, 20, 20, 0.82);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    padding-top: 64px;
    padding-bottom: 48px;
    text-align: center;
  }

  .footer-contact {
    font-style: normal;
    color: #d8d8d8;
    font-size: 16px;
    line-height: 1.8;
  }

  .footer-contact a { color: var(--color-white); }
  .footer-contact a:hover { color: var(--color-orange); }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    font-family: var(--font-heading);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-nav a { color: var(--color-white); }
  .footer-nav a:hover { color: var(--color-orange); }
  .footer-nav-sep { color: rgba(255, 255, 255, 0.35); }

  .footer-socials {
    display: flex;
    gap: 18px;
  }

  .footer-socials a {
    color: var(--color-white);
    display: inline-flex;
    padding: 6px;
  }

  .footer-socials a:hover { color: var(--color-orange); }

  .footer-copyright {
    margin: 0;
    color: #9a9a9a;
    font-size: 14px;
  }
</style>
