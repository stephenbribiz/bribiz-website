---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => !data.archived)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog - BriBiz"
  description="Industry news and practical advice on music business, finances, royalties, touring, and building a sustainable creative career — from the BriBiz team."
>
  <PageHero title="Industry News + Blog" />

  <section class="blog-list">
    <div class="container">
      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/${post.id}/`} class="post-card">
            <Image
              src={post.data.image}
              alt={post.data.imageAlt || post.data.title}
              width={600}
              height={338}
            />
            <div class="post-card-body">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="post-more">Read More »</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-list {
    padding: 64px 0 80px;
    background: var(--color-gray-section);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .post-card {
    background: var(--color-white);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    color: var(--color-text);
  }

  .post-card-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card time {
    font-size: 14px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }

  .post-card h2 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .post-card p {
    font-size: 16px;
    color: var(--color-text-muted);
    flex: 1;
  }

  .post-more {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-orange-dark);
    font-size: 15px;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
