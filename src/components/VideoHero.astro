---
import poster from '../assets/backgrounds/video-poster.jpg';
---

<section class="video-hero">
  <video
    class="video-hero-bg"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={poster.src}
    aria-hidden="true"
  >
    <source src="/video/hero-bg.mp4" type="video/mp4" />
  </video>
  <div class="video-hero-overlay">
    <div class="container video-hero-content">
      <h1>Business Management for Creatives</h1>
      <p class="video-hero-sub">
        Helping you gain control over your finances and grow your creative business
        – without losing your soul.
      </p>
      <a href="/whatwedo/" class="btn btn-large">Learn More</a>
    </div>
  </div>
</section>

<style>
  .video-hero {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  .video-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-hero-overlay {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.25);
  }

  .video-hero-content {
    max-width: 720px;
    margin: 0;
    padding: 80px 24px 80px max(24px, calc((100vw - var(--content-width)) / 2 + 24px));
    color: var(--color-white);
  }

  .video-hero-content h1 {
    color: var(--color-white);
    font-size: 56px;
    margin-bottom: 16px;
  }

  .video-hero-sub {
    font-size: 24px;
    line-height: 1.45;
    margin-bottom: 32px;
    color: rgba(255, 255, 255, 0.95);
  }

  @media (max-width: 800px) {
    .video-hero { min-height: 64vh; }
    .video-hero-content h1 { font-size: 36px; }
    .video-hero-sub { font-size: 19px; }
  }
</style>
