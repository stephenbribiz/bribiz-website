---
import { getImage } from 'astro:assets';
import posterSrc from '../assets/backgrounds/video-poster.jpg';

// Optimized poster renders immediately as the LCP-safe background; the video
// itself is attached by JS only on desktop-sized viewports with no data-saver
// or reduced-motion preference, after the page has loaded.
const poster = await getImage({ src: posterSrc, width: 1600, format: 'webp' });
---

<section class="video-hero">
  <video
    class="video-hero-bg"
    muted
    loop
    playsinline
    preload="none"
    poster={poster.src}
    aria-hidden="true"
    data-hero-video
    data-webm="/video/hero-bg.webm"
    data-mp4="/video/hero-bg.mp4"
  ></video>
  <div class="video-hero-overlay">
    <div class="container video-hero-content">
      <h1>Business Management for Creatives</h1>
      <p class="video-hero-sub">
        Helping you gain control over your finances and grow your creative business
        – without losing your soul.
      </p>
      <a href="/whatwedo/" class="btn btn-large btn-hero">See What We Do</a>
    </div>
  </div>
</section>

<script>
  // Attach the background video only when it won't hurt the experience:
  // desktop-sized viewport, no reduced-motion preference, no data saver,
  // and not a constrained connection. Mobile and slow connections keep the
  // static poster image.
  const video = document.querySelector<HTMLVideoElement>('[data-hero-video]');

  const wantsVideo = () => {
    if (!window.matchMedia('(min-width: 768px)').matches) return false;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return false;
    const conn = (navigator as any).connection;
    if (conn?.saveData) return false;
    if (conn?.effectiveType && /2g/.test(conn.effectiveType)) return false;
    return true;
  };

  if (video && wantsVideo()) {
    const attach = () => {
      const webm = document.createElement('source');
      webm.src = video.dataset.webm!;
      webm.type = 'video/webm';
      const mp4 = document.createElement('source');
      mp4.src = video.dataset.mp4!;
      mp4.type = 'video/mp4';
      video.append(webm, mp4);
      video.load();
      video.play().catch(() => {});
    };
    if (document.readyState === 'complete') attach();
    else window.addEventListener('load', attach, { once: true });
  }
</script>

<style>
  /* Proportions matched to the original: ~460px tall at 1440px wide,
     scaling with viewport width rather than height. */
  .video-hero {
    position: relative;
    min-height: clamp(380px, 32vw, 470px);
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  .video-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* The original design has no dark overlay: the video footage is light and
     washed out, with charcoal text sitting directly on it. */
  .video-hero-overlay {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .video-hero-content {
    /* border-box: budget for the dynamic left padding plus ~640px of text */
    max-width: calc(640px + max(24px, calc((100vw - var(--content-width)) / 2 + 24px)));
    margin: 0;
    padding: 60px 24px 60px max(24px, calc((100vw - var(--content-width)) / 2 + 24px));
    color: var(--color-text);
  }

  .video-hero-content h1 {
    color: var(--color-text);
    font-size: 34px;
    margin-bottom: 26px;
  }

  .video-hero-sub {
    font-size: 17px;
    line-height: 1.5;
    max-width: 480px;
    margin-bottom: 34px;
    color: var(--color-text);
  }

  /* Wide deep-orange hero button with white text, like the original
     "Learn More" — #c24a10 keeps white text at 4.91:1 (WCAG AA). */
  .video-hero-content :global(.btn-hero) {
    background: var(--color-orange-dark);
    color: var(--color-white);
    display: block;
    max-width: 480px;
    text-align: center;
    font-size: 16px;
    padding: 17px 36px;
  }

  .video-hero-content :global(.btn-hero:hover) {
    background: var(--color-orange);
    color: var(--color-text);
  }

  @media (max-width: 800px) {
    .video-hero { min-height: 320px; }
    .video-hero-content { padding-top: 48px; padding-bottom: 48px; }
    .video-hero-content h1 { font-size: 28px; }
    .video-hero-sub { font-size: 16px; }
  }
</style>
